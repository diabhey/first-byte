# LiveKit Cloud credentials.
# After signing up at https://cloud.livekit.io, run `lk cloud auth` and copy
# these from your project's Settings page.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Moss credentials.
# Sign up at https://docs.moss.dev, create a project, then copy these from
# the project settings page. Pick an index name unique to you.
MOSS_PROJECT_ID=
MOSS_PROJECT_KEY=
MOSS_INDEX_NAME=firstbyte-your-handle
